{
  "name": "caudri-next",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -k \"pnpm dev:web\" \"pnpm dev:realtime\"",
    "dev:web": "next dev --hostname 0.0.0.0 --port 3000",
    "dev:realtime": "tsx src/realtime/realtime-server.ts",
    "dev:traffic-light": "tsx src/realtime/traffic-light-mock-server.ts",
    "build": "next build",
    "start": "concurrently -k \"pnpm start:web\" \"pnpm start:realtime\"",
    "start:web": "next start --hostname 0.0.0.0 --port 3000",
    "start:realtime": "NODE_ENV=production tsx src/realtime/realtime-server.ts"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "framer-motion": "^12.38.0",
    "hls.js": "^1.6.16",
    "lucide-react": "^1.14.0",
    "next": "16.2.4",
    "pdfjs-dist": "^5.7.284",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.6.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
