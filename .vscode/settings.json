{
  "actionButtons": {
    "defaultColor": "white",
    "loadNpmCommands": false,
    "reloadButton": "$(sync)",
    "commands": [
      {
        "name": "$(rocket) Start Dashboard",
        "color": "green",
        "singleInstance": true,
        "cwd": "${workspaceFolder}",
        "command": "pnpm dev"
      },
      {
        "name": "$(debug-stop) Stop Dashboard",
        "color": "#aa0202",
        "command": "pkill -f 'server.ts' || true"
      }
    ]
  }
}
